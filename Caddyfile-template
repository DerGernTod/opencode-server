# rename this to "Caddyfile"
opencode.yourdomain.com {
    # 1. Ask Authelia if this person is logged in
    forward_auth authelia:9091 {
        uri /api/authz/forward-auth?rd=https://auth.yourdomain.com
        copy_headers Remote-User Remote-Groups Remote-Name
    }

    # 2. If yes, go to OpenCode
    reverse_proxy opencode:3001
}

auth.yourdomain.com {
    reverse_proxy authelia:9091 {
        # This ensures the original IP is passed correctly
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}

# pr12-project.prs.yourdomain.com
*.prs.yourdomain.com {
    tls {
        dns hetzner {$HETZNER_API_KEY}
        propagation_delay 30s
    }
    @get_parts header_regexp pr_host Host ^pr([0-9]+)-([a-z0-9-]+)\.prs
    
    handle @get_parts {
        # This matches the --name we gave the container in the Action
        reverse_proxy pr-{re.pr_host.1}-{re.pr_host.2}:3000
    }
    
    # Optional: Keep it private
    forward_auth authelia:9091 {
        uri /api/authz/forward-auth?rd=https://auth.yourdomain.com
        copy_headers Remote-User Remote-Groups Remote-Name
    }
}
*.projects.your-domain.com {
    tls {
        dns hetzner {$HETZNER_API_KEY}
        propagation_delay 60s
        propagation_timeout -1
    }
    @get_parts header_regexp project Host ^([^.]+)\.projects

    handle @get_parts {
        # This matches the --name we gave the container in the Action
        reverse_proxy project-{re.project.1}:3000
    }

    forward_auth authelia:9091 {
        uri /api/authz/forward-auth?rd=https://auth.your-domain.com
        copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
    }
}